# 生产环境必须配置，替换成你自己的强随机字符串
HOSPITAL_JWT_SECRET=replace-with-a-very-strong-secret

# 小范围内测建议先写你的访问地址；可写多个，逗号分隔
# 例如：HOSPITAL_CORS_ORIGINS=http://111.231.44.21:5173
HOSPITAL_CORS_ORIGINS=http://111.231.44.21:5173

# GitHub Actions 推送到 GHCR 后，服务器 docker compose pull 会拉取下面两个镜像
# 仓库名需要全部小写，例如：ghcr.io/cpiforheal/design_pro_forhos/api:latest
APP_IMAGE=ghcr.io/your-github-user/your-repository/api:latest
WEB_IMAGE=ghcr.io/your-github-user/your-repository/web:latest
