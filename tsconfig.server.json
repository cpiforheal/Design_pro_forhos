{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["esnext", "dom"],
    "types": ["node", "vite/client"],
    "skipLibCheck": true
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.d.ts",
    "tests/**/*.ts",
    "src/env.d.ts",
    "src/types/assessment.ts",
    "src/types/server-build.d.ts",
    "src/data/assessmentData.ts",
    "src/utils/assessment/scoring.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
